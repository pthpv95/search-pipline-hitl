# Anthropic — leave blank to use OpenCode Go instead
ANTHROPIC_API_KEY=
TAVILY_API_KEY=your_tavily_key_here

# OpenCode Go ($5 first month, then $10/month)
LLM_PROVIDER=opencode_go
OPENCODE_GO_API_KEY=your_go_key
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_MODEL=glm-5

# Trial gating — new users get TRIAL_LIMIT free runs before API key is required
TRIAL_LIMIT=2
API_KEYS=your-api-key-here
